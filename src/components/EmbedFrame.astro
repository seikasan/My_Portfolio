---
const { item } = Astro.props;

const provider = item?.provider?.toLowerCase?.() ?? 'external';
const label = item?.label ?? 'Media';
const rawUrl = item?.url ?? '';
const providerLabel = provider === 'external' ? 'Link' : provider;
let embedUrl = rawUrl;
let useIframe = false;
let compact = false;

if (provider === 'youtube' && rawUrl) {
  const match = rawUrl.match(/(?:v=|youtu\.be\/|embed\/)([A-Za-z0-9_-]{11})/);
  if (match) {
    embedUrl = `https://www.youtube.com/embed/${match[1]}`;
    useIframe = true;
  }
}

if (provider === 'soundcloud' && rawUrl) {
  embedUrl = `https://w.soundcloud.com/player/?url=${encodeURIComponent(rawUrl)}`;
  useIframe = true;
  compact = true;
}

if (provider === 'applemusic' && rawUrl.includes('/embed')) {
  useIframe = true;
  compact = true;
}

if (provider === 'niconico' && rawUrl.includes('ext.nicovideo.jp')) {
  useIframe = true;
}
---

<div class="media-card">
  <div class:list={['embed-frame', compact && 'embed-frame--compact']}>
    {useIframe ? (
      <iframe
        src={embedUrl}
        title={label}
        loading="lazy"
        allow="autoplay; encrypted-media; picture-in-picture"
        allowfullscreen
      />
    ) : rawUrl ? (
      <a class="embed-placeholder" href={rawUrl} target="_blank" rel="noreferrer">
        <span>{providerLabel}</span>
        <strong>{label}</strong>
        <small>Open external media</small>
      </a>
    ) : (
      <div class="embed-placeholder">
        <span>{providerLabel}</span>
        <strong>{label}</strong>
        <small>Media URL unavailable</small>
      </div>
    )}
  </div>
</div>
