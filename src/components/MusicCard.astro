---
import EmbedFrame from './EmbedFrame.astro';

const { entry } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const href = `${base}music-video/${entry.id}/`;
const primaryEmbed = entry.data.embeds[0];
---

<article class="card music-card">
  <div class="card-body">
    <div class="card-heading">
      <h3><a href={href}>{entry.data.title}</a></h3>
      <p class="card-meta">{entry.data.releaseLabel}</p>
      <p class="card-meta">{entry.data.category}</p>
    </div>
    <p>{entry.data.summary}</p>
    {primaryEmbed && <EmbedFrame item={primaryEmbed} />}
    {entry.data.achievements.length > 0 && (
      <ul class="simple-list">
        {entry.data.achievements.map((item) => <li>{item}</li>)}
      </ul>
    )}
    <a class="text-link" href={href}>View details</a>
  </div>
</article>
