---
const { entry } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const href = `${base}games/${entry.id}/`;
---

<article class="card game-card">
  <a class="thumbnail thumbnail--game" href={href} aria-label={`View details for ${entry.data.title}`}>
    <span>{entry.data.thumbnailLabel || entry.data.title}</span>
  </a>
  <div class="card-body">
    <div class="card-heading">
      <h3><a href={href}>{entry.data.title}</a></h3>
      <p class="card-meta">{entry.data.period}</p>
      <p class="card-meta">{entry.data.teamSize} / {entry.data.roles.join(' / ')}</p>
    </div>
    <p>{entry.data.summary}</p>
    <dl class="meta-grid">
      <div>
        <dt>Technology</dt>
        <dd>{entry.data.technologies.join(', ')}</dd>
      </div>
      <div>
        <dt>Contribution</dt>
        <dd>{entry.data.contribution}</dd>
      </div>
    </dl>
    <a class="text-link" href={href}>View details</a>
  </div>
</article>
