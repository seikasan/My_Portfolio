---
import styles from "./SkillGrid.module.css";

interface SkillItem {
  name: string;
  years: string;
}

interface SkillGroup {
  label: string;
  items: readonly SkillItem[];
}

interface Props {
  groups: readonly SkillGroup[];
}

const { groups } = Astro.props as Props;
---

<div class={styles.grid}>
  {groups.map((group) => (
    <section class={styles.group}>
      <h3>{group.label}</h3>
      <ul>
        {group.items.map((item) => (
          <li>
            <span>{item.name}</span>
            <strong>{item.years}</strong>
          </li>
        ))}
      </ul>
    </section>
  ))}
</div>
