---
import type { CollectionEntry } from "astro:content";
import styles from "./ProjectPreviewDetail.module.css";
import embedStyles from "./EmbedFrame.module.css";
import { projectPath, withBase } from "@utils/paths";

interface Props {
  project: CollectionEntry<"projects">;
}

const { project } = Astro.props as Props;

const projectHref = projectPath(project.slug);
const memberLabel =
  typeof project.data.members === "number" ? `${project.data.members}人` : project.data.members;
const teamInfo =
  memberLabel === project.data.teamType ? memberLabel : `${project.data.teamType} / ${memberLabel}`;

const previewBlocks =
  project.data.previewBlocks.length > 0
    ? project.data.previewBlocks.map((block) =>
        block.type === "image" ? { ...block, src: withBase(block.src) } : block
      )
    : [
        {
          type: "text" as const,
          title: "作品概要",
          body: project.data.summaryLong || project.data.myContribution
        },
        ...(project.data.myContribution &&
        project.data.myContribution !== (project.data.summaryLong || project.data.myContribution)
          ? [
              {
                type: "text" as const,
                title: "担当内容",
                body: project.data.myContribution
              }
            ]
          : []),
        {
          type: "image" as const,
          src: withBase(project.data.gallery[0]?.src ?? project.data.thumbnail),
          alt: project.data.gallery[0]?.alt ?? `${project.data.title} のイメージ`,
          caption: project.data.gallery[0]?.caption
        }
      ];

const providerLabel = {
  youtube: "YouTube",
  soundcloud: "SoundCloud",
  "apple-music": "Apple Music"
} as const;
---

<article class={styles.panel}>
  <div class={styles.header}>
    <div class={styles.copy}>
      <p class={styles.eyebrow}>Selected Work</p>
      <h3>{project.data.title}</h3>
      <p class={styles.summary}>{project.data.summaryShort}</p>
    </div>
    <a class="button button--secondary" href={projectHref}>作品詳細へ</a>
  </div>

  <dl class={styles.metaGrid}>
    <div>
      <dt>期間</dt>
      <dd>{project.data.periodLabel}</dd>
    </div>
    <div>
      <dt>担当</dt>
      <dd>{project.data.primaryRole}</dd>
    </div>
    <div>
      <dt>エンジン</dt>
      <dd>{project.data.engine}</dd>
    </div>
    <div>
      <dt>形式</dt>
      <dd>{project.data.format}</dd>
    </div>
    <div>
      <dt>制作体制</dt>
      <dd>{teamInfo}</dd>
    </div>
  </dl>

  <div class={styles.blocks}>
    {previewBlocks.map((block) => {
      if (block.type === "text") {
        const paragraphs = block.body.split(/\r?\n/).filter(Boolean);

        return (
          <section class={styles.textBlock}>
            {block.title && <h4>{block.title}</h4>}
            <div class={styles.paragraphs}>
              {paragraphs.map((paragraph) => (
                <p>{paragraph}</p>
              ))}
            </div>
          </section>
        );
      }

      if (block.type === "image") {
        return (
          <figure class={styles.imageBlock}>
            <img src={block.src} alt={block.alt} loading="lazy" />
            {block.caption && <figcaption>{block.caption}</figcaption>}
          </figure>
        );
      }

      return (
        <section class={styles.embedBlock}>
          <div
            class={embedStyles.embed}
            data-embed-root="true"
            data-provider={block.provider}
            data-embed-url={block.embedUrl}
            data-title={block.title}
          >
            <div class={embedStyles.placeholder} data-embed-placeholder>
              <span class={embedStyles.provider}>{providerLabel[block.provider]}</span>
              <h3>{block.title}</h3>
              {block.note && <p>{block.note}</p>}
              <button type="button" class="button button--primary" data-embed-button>
                プレイヤーを表示
              </button>
            </div>
            <div class={embedStyles.frameArea} data-embed-target hidden></div>
            <a class={embedStyles.external} href={block.externalUrl} target="_blank" rel="noreferrer">
              {providerLabel[block.provider]} で開く
            </a>
          </div>
        </section>
      );
    })}
  </div>
</article>
