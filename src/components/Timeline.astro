---
import styles from "./Timeline.module.css";

interface Item {
  date: string;
  title: string;
  description: string;
}

interface Props {
  items: readonly Item[];
}

const { items } = Astro.props as Props;
---

<ol class={styles.timeline}>
  {items.map((item) => (
    <li>
      <div>
        <p>{item.date}</p>
        <h3>{item.title}</h3>
        <span>{item.description}</span>
      </div>
    </li>
  ))}
</ol>
