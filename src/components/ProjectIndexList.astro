---
import type { CollectionEntry } from "astro:content";
import styles from "./ProjectIndexList.module.css";
import { projectPath } from "@utils/paths";

interface Props {
  items: readonly CollectionEntry<"projects">[];
}

const { items } = Astro.props as Props;

const getStatusLabel = (status: CollectionEntry<"projects">["data"]["status"]) => {
  if (status === "archive") {
    return "Archive";
  }

  if (status === "in-progress") {
    return "In Progress";
  }

  return undefined;
};
---

<div class={styles.layout}>
  {items.length > 0 ? (
    items.map((project, index) => {
      const statusLabel = getStatusLabel(project.data.status);

      return (
        <a
          class={styles.card}
          href={projectPath(project.slug)}
          style={`--reveal-delay: ${70 + index * 60}ms;`}
          data-reveal
        >
          <div class={styles.cardHeader}>
            <div class={styles.metaRow}>
              <span class={styles.metaChip}>{project.data.periodLabel}</span>
              <span class={styles.metaChip}>{project.data.engine}</span>
              {statusLabel && (
                <span
                  class={`${styles.statusChip} ${
                    project.data.status === "archive" ? styles.archive : styles.inProgress
                  }`}
                >
                  {statusLabel}
                </span>
              )}
            </div>
            <h3>{project.data.title}</h3>
          </div>

          <p class={styles.summary}>{project.data.summaryShort}</p>

          <dl class={styles.specGrid}>
            <div>
              <dt>担当</dt>
              <dd>{project.data.primaryRole}</dd>
            </div>
            <div>
              <dt>形式</dt>
              <dd>{project.data.format}</dd>
            </div>
            <div>
              <dt>技術</dt>
              <dd>{project.data.engine}</dd>
            </div>
          </dl>

          <span class={styles.linkLabel}>詳細を見る</span>
        </a>
      );
    })
  ) : (
    <p class={styles.empty}>現在掲載中の作品はありません。</p>
  )}
</div>
