---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import EmbedFrame from '../../components/EmbedFrame.astro';

export async function getStaticPaths() {
  const entries = await getCollection('games');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry }
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const root = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout title={entry.data.title} description={entry.data.summary}>
  <article class="detail-page">
    <section class="section section--page">
      <a class="back-link" href={`${root}games/`}>Back to games</a>
      <div class="detail-hero">
        <div class="panel">
          <p class="eyebrow">Works - Games</p>
          <h1>{entry.data.title}</h1>
          <p class="hero-description">{entry.data.summary}</p>
        </div>
        <div class="detail-meta-box">
          <p>
            <strong>Period</strong>
            <span>{entry.data.period}</span>
          </p>
          <p>
            <strong>Team</strong>
            <span>{entry.data.teamSize}</span>
          </p>
          <p>
            <strong>Roles</strong>
            <span>{entry.data.roles.join(' / ')}</span>
          </p>
        </div>
      </div>
    </section>

    <section class="section detail-grid">
      <div class="panel">
        <h2>Overview</h2>
        <p>{entry.data.summary}</p>
      </div>
      <div class="panel">
        <h2>Technology</h2>
        <ul class="inline-list">
          {entry.data.technologies.map((item) => <li>{item}</li>)}
        </ul>
      </div>
      <div class="panel">
        <h2>Contribution</h2>
        <p>{entry.data.contribution}</p>
      </div>
      <div class="panel">
        <h2>Highlights</h2>
        <ul class="simple-list">
          {entry.data.highlights.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </section>

    <section class="section detail-grid">
      <div class="panel">
        <h2>Media</h2>
        {entry.data.playMedia.length > 0 ? (
          <div class="media-stack">
            {entry.data.playMedia.map((item) => <EmbedFrame item={item} />)}
          </div>
        ) : (
          <p class="empty-copy">No embedded media has been added yet.</p>
        )}
      </div>
      <div class="panel">
        <h2>Downloads</h2>
        {entry.data.downloads.length > 0 ? (
          <ul class="simple-list">
            {entry.data.downloads.map((item) => (
              <li><a class="text-link" href={item.url} target="_blank" rel="noreferrer">{item.label}</a></li>
            ))}
          </ul>
        ) : (
          <p class="empty-copy">No download links are currently listed.</p>
        )}
      </div>
    </section>

    <section class="section">
      <div class="panel">
        <h2>References</h2>
        {entry.data.references.length > 0 ? (
          <ul class="simple-list">
            {entry.data.references.map((item) => (
              <li><a class="text-link" href={item.url} target="_blank" rel="noreferrer">{item.label}</a></li>
            ))}
          </ul>
        ) : (
          <p class="empty-copy">No reference links are currently listed.</p>
        )}
      </div>
    </section>

    {entry.body.trim() && (
      <section class="section">
        <div class="panel prose">
          <h2>Notes</h2>
          <Content />
        </div>
      </section>
    )}
  </article>
</BaseLayout>
