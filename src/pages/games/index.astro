---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import GameCard from '../../components/GameCard.astro';

const games = (await getCollection('games')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Works - Games" description="Selected game projects.">
  <section class="section section--page">
    <SectionHeader
      eyebrow="Works - Games"
      title="All Games"
      description="A full list of game projects with team size, roles, stack, and contribution."
    />
    <div class="card-grid">
      {games.map((entry) => <GameCard entry={entry} />)}
    </div>
  </section>
</BaseLayout>
