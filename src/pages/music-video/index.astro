---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import MusicCard from '../../components/MusicCard.astro';

const musicEntries = (await getCollection('music-video')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Works - Music / Video" description="Selected music and video work.">
  <section class="section section--page">
    <SectionHeader
      eyebrow="Works - Music / Video"
      title="All Music / Video Work"
      description="A full list of music and video projects with previews, notes, and external links."
    />
    <div class="card-grid card-grid--music">
      {musicEntries.map((entry) => <MusicCard entry={entry} />)}
    </div>
  </section>
</BaseLayout>
