---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import EmbedFrame from "@components/EmbedFrame.astro";
import { withBase } from "@utils/paths";

const musicEntries = (await getCollection("music")).sort(
  (left, right) => left.data.sortOrder - right.data.sortOrder
);
const originalWorks = musicEntries.filter((entry) => entry.data.category === "original");
const gameSoundWorks = musicEntries.filter((entry) => entry.data.category === "game-sound");
---

<BaseLayout title="音楽作品" description="個人音楽作品とゲームサウンドをまとめたページ。">
  <section class="section-card music-page-hero" data-reveal>
    <div class="section-heading">
      <p class="section-heading__eyebrow">Original Music</p>
      <h1>音楽・動画作品</h1>
      <p class="section-heading__lead">
        個人制作の楽曲と、ゲームに使ったサウンドトラックを分けて見られるように整理しています。
      </p>
    </div>
  </section>

  <section class="section-card" data-reveal>
    <div class="section-heading">
      <p class="section-heading__eyebrow">Original</p>
      <h2>個人楽曲</h2>
    </div>
    <div class="album-grid">
      {originalWorks.map((work, index) => (
        <article
          class={`music-page-card ${index === 0 ? "music-page-card--feature" : ""}`}
          style={`--reveal-delay: ${80 + index * 80}ms;`}
          data-reveal
        >
          <img src={withBase(work.data.thumbnail)} alt={`${work.data.title} のサムネイル`} loading="lazy" />
          <div class="music-page-card__body">
            <div class="music-page-card__meta">
              <span>{work.data.kind}</span>
              <span>{work.data.playCount}</span>
            </div>
            <h3>{work.data.title}</h3>
            <p>{work.data.theme}</p>
            <ul class="tag-list">
              {work.data.responsibilities.map((role) => (
                <li>{role}</li>
              ))}
            </ul>
            {work.data.embedProvider && work.data.embedUrl ? (
              <EmbedFrame
                provider={work.data.embedProvider}
                title={work.data.title}
                embedUrl={work.data.embedUrl}
                externalUrl={work.data.externalLinks[0]?.url}
              />
            ) : (
              <p class="empty-state">
                Apple Music などの埋め込み URL を設定すると、ここにプレーヤーが表示されます。
              </p>
            )}
            {work.data.externalLinks.length > 0 && (
              <div class="inline-links">
                {work.data.externalLinks.map((link) => (
                  <a href={link.url} target="_blank" rel="noreferrer">
                    {link.label}
                  </a>
                ))}
              </div>
            )}
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section-card section-card--quiet" data-reveal>
    <div class="section-heading">
      <p class="section-heading__eyebrow">Game Sound</p>
      <h2>ゲームサウンド</h2>
    </div>
    <div class="sound-grid">
      {gameSoundWorks.map((work, index) => (
        <article
          class="music-page-card music-page-card--wide"
          style={`--reveal-delay: ${100 + index * 90}ms;`}
          data-reveal
        >
          <img src={withBase(work.data.thumbnail)} alt={`${work.data.title} のサムネイル`} loading="lazy" />
          <div class="music-page-card__body">
            <div class="music-page-card__meta">
              <span>{work.data.kind}</span>
              <span>{work.data.playCount}</span>
            </div>
            <h3>{work.data.title}</h3>
            <p>{work.data.theme}</p>
            <ul class="tag-list">
              {work.data.responsibilities.map((role) => (
                <li>{role}</li>
              ))}
            </ul>
            {work.data.embedProvider && work.data.embedUrl ? (
              <EmbedFrame
                provider={work.data.embedProvider}
                title={work.data.title}
                embedUrl={work.data.embedUrl}
                externalUrl={work.data.externalLinks[0]?.url}
              />
            ) : (
              <p class="empty-state">
                SoundCloud の埋め込み URL を設定すると、ここにプレーヤーが表示されます。
              </p>
            )}
            {work.data.externalLinks.length > 0 && (
              <div class="inline-links">
                {work.data.externalLinks.map((link) => (
                  <a href={link.url} target="_blank" rel="noreferrer">
                    {link.label}
                  </a>
                ))}
              </div>
            )}
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
