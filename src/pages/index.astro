---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import GameCard from '../components/GameCard.astro';
import MusicCard from '../components/MusicCard.astro';
import { siteMeta, profile, skills, contact } from '../data/site.js';

const games = (await getCollection('games')).sort((a, b) => a.data.order - b.data.order);
const musicEntries = (await getCollection('music-video')).sort((a, b) => a.data.order - b.data.order);
const root = import.meta.env.BASE_URL;
---

<BaseLayout title="Home" description={siteMeta.intro}>
  <section class="hero section">
    <div class="hero-copy">
      <p class="eyebrow">Portfolio</p>
      <h1>{siteMeta.ownerName}</h1>
      <p class="hero-role">{siteMeta.role}</p>
      <p class="hero-tagline">{siteMeta.tagline}</p>
      <p class="hero-description">{siteMeta.intro}</p>
      <div class="hero-actions">
        <a class="button" href="#works-games">Works - Games</a>
        <a class="button button--ghost" href="#works-music">Works - Music / Video</a>
      </div>
    </div>
    <div class="hero-panel">
      <div class="hero-stat">
        <strong>{games.length}</strong>
        <span>Team Games</span>
      </div>
      <div class="hero-stat">
        <strong>{musicEntries.length}</strong>
        <span>Music / Video Works</span>
      </div>
      <div class="hero-stat">
        <strong>4 Roles</strong>
        <span>Program / Sound / Scenario / 3D</span>
      </div>
    </div>
  </section>

  <section class="section" id="about">
    <SectionHeader
      eyebrow="About / Profile"
      title="創作の背景"
      description={profile.comment}
    />
    <div class="two-column">
      <div class="panel">
        <h3>経歴</h3>
        <ul class="timeline-list">
          {profile.timeline.map((item) => (
            <li>
              <span>{item.label}</span>
              <p>{item.text}</p>
            </li>
          ))}
        </ul>
      </div>
      <div class="stack">
        <div class="panel">
          <h3>学歴</h3>
          <ul class="simple-list">
            {profile.education.map((item) => <li>{item}</li>)}
          </ul>
        </div>
        <div class="panel">
          <h3>イベント歴</h3>
          <ul class="simple-list">
            {profile.events.map((item) => <li>{item}</li>)}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="skills">
    <SectionHeader
      eyebrow="Skills"
      title="できること"
      description={skills.summary}
    />
    <div class="two-column">
      <div class="panel">
        <h3>Languages</h3>
        <ul class="skill-list">
          {skills.languages.map((item) => (
            <li>
              <strong>{item.name}</strong>
              <span>{item.experience}</span>
            </li>
          ))}
        </ul>
      </div>
      <div class="panel">
        <h3>Tools</h3>
        <ul class="skill-list">
          {skills.tools.map((item) => (
            <li>
              <strong>{item.name}</strong>
              <span>{item.experience}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="section" id="works-games">
    <SectionHeader
      eyebrow="Works - Games"
      title="ゲーム制作"
      description="作品全体の説明と、自分の担当範囲が混ざらないように整理しています。"
      actionHref={`${root}games/`}
      actionLabel="ゲーム一覧へ"
    />
    <div class="card-grid">
      {games.map((entry) => <GameCard entry={entry} />)}
    </div>
  </section>

  <section class="section" id="works-music">
    <SectionHeader
      eyebrow="Works - Music / Video"
      title="音楽・動画"
      description="視聴導線を優先し、作品説明は短く保っています。"
      actionHref={`${root}music-video/`}
      actionLabel="音楽・動画一覧へ"
    />
    <div class="card-grid card-grid--music">
      {musicEntries.map((entry) => <MusicCard entry={entry} />)}
    </div>
  </section>

  <section class="section" id="contact">
    <SectionHeader
      eyebrow="Contact"
      title="連絡先"
      description="公開用のURLとメールアドレスに差し替えてください。"
    />
    <div class="two-column">
      <a class="panel contact-card" href={contact.github} target="_blank" rel="noreferrer">
        <strong>GitHub</strong>
        <span>{contact.github}</span>
      </a>
      <a class="panel contact-card" href={`mailto:${contact.email}`}>
        <strong>Email</strong>
        <span>{contact.email}</span>
      </a>
    </div>
  </section>
</BaseLayout>

