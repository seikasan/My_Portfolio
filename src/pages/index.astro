---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import FeaturedGameCard from "@components/FeaturedGameCard.astro";
import Hero from "@components/Hero.astro";
import ProjectIndexList from "@components/ProjectIndexList.astro";
import SkillGrid from "@components/SkillGrid.astro";
import Timeline from "@components/Timeline.astro";
import {
  activities,
  contactLinks,
  heroMetrics,
  heroTechStack,
  profileTimeline,
  siteMeta,
  skillGroups,
  strengths
} from "@content/site";
import { musicPath, projectPath, withBase } from "@utils/paths";

const projects = (await getCollection("projects")).sort(
  (left, right) => left.data.sortOrder - right.data.sortOrder
);
const featuredProjects = projects.filter((project) => project.data.featured).slice(0, 3);
const circleWorks = projects.filter((project) => project.data.workCategory === "circle");
const otherWorks = projects.filter((project) => project.data.workCategory !== "circle");
const musicWorks = (await getCollection("music"))
  .filter((item) => item.data.featured)
  .sort((left, right) => left.data.sortOrder - right.data.sortOrder)
  .slice(0, 3);

const heroPreviews = featuredProjects.slice(0, 3).map((project) => ({
  title: project.data.title,
  href: projectPath(project.slug),
  image: withBase(project.data.thumbnail),
  period: project.data.periodLabel,
  engine: project.data.engine,
  role: project.data.primaryRole
}));

const [primaryProject, ...secondaryProjects] = featuredProjects;
const leadStrength = strengths[0];
const supportingStrengths = strengths.slice(1);
const workGroups = [
  {
    title: "大学・サークル制作",
    description: "学内チームやサークルで担当した作品を、制作期間と役割がすぐ分かる形で整理しています。",
    items: circleWorks
  },
  {
    title: "個人制作 / その他",
    description: "個人制作や別チームの作品を、今後追加しやすい形で同じ一覧にまとめています。",
    items: otherWorks
  }
] as const;

const normalizedContactLinks = contactLinks.map((link) => ({
  label: link.label,
  url: "url" in link ? link.url : undefined,
  note: link.note
}));
---

<BaseLayout>
  <Hero
    name={siteMeta.name}
    roleLine={siteMeta.roleLine}
    summary={siteMeta.heroSummary}
    techStack={heroTechStack}
    metrics={heroMetrics}
    previews={heroPreviews}
    primaryHref="#games"
    secondaryHref="#works"
    musicHref={musicPath()}
  />

  <section class="section-card section-card--quiet" id="strengths" data-reveal>
    <div class="section-heading">
      <p class="section-heading__eyebrow">Role Proof</p>
      <h2>作品で証明できる担当領域</h2>
      <p class="section-heading__lead">
        できることを広く並べるのではなく、どの作品で何を作ったかが伝わる証拠ベースで整理しています。
      </p>
    </div>
    <div class="strengths-layout">
      <article class="insight-card insight-card--feature">
        <p class="insight-card__eyebrow">Main Strength</p>
        <h3>{leadStrength.title}</h3>
        <p>{leadStrength.summary}</p>
        <small>{leadStrength.proof}</small>
      </article>
      <div class="insight-stack">
        {supportingStrengths.map((item, index) => (
          <article class="insight-card" style={`--reveal-delay: ${120 + index * 70}ms;`} data-reveal>
            <h3>{item.title}</h3>
            <p>{item.summary}</p>
            <small>{item.proof}</small>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-card section-card--spotlight" id="games" data-reveal>
    <div class="section-heading">
      <p class="section-heading__eyebrow">Featured Games</p>
      <h2>代表作 3 本</h2>
      <p class="section-heading__lead">
        採用・審査向けに、何を担当した作品なのかが一目で分かる 3 本だけを先に強く見せています。
      </p>
    </div>
    <div class="featured-cluster">
      {primaryProject && <FeaturedGameCard project={primaryProject} variant="primary" delayMs={60} />}
      <div class="featured-cluster__grid">
        {secondaryProjects.map((project, index) => (
          <FeaturedGameCard project={project} variant="secondary" delayMs={140 + index * 90} />
        ))}
      </div>
    </div>
  </section>

  <section class="section-card section-card--quiet" id="works" data-reveal>
    <div class="section-heading">
      <p class="section-heading__eyebrow">All Works</p>
      <h2>全ゲーム作品</h2>
      <p class="section-heading__lead">
        代表作以外も含めて、制作履歴を短時間で俯瞰できる一覧にまとめています。
      </p>
    </div>
    <ProjectIndexList groups={workGroups} />
  </section>

  <section class="section-card section-card--music" data-reveal>
    <div class="section-heading">
      <p class="section-heading__eyebrow">Sound Portfolio</p>
      <h2>音楽作品への導線</h2>
      <p class="section-heading__lead">
        ゲームサウンドと個人音楽は別ページにまとめ、トップでは担当できる領域だけを短く示しています。
      </p>
    </div>
    <div class="sound-proof-grid">
      {musicWorks.map((work, index) => (
        <article class="sound-proof-card" style={`--reveal-delay: ${80 + index * 80}ms;`} data-reveal>
          <p class="sound-proof-card__eyebrow">{work.data.kind}</p>
          <div class="sound-proof-card__body">
            <h3>{work.data.title}</h3>
            <p>{work.data.theme}</p>
            <div class="sound-proof-card__meta">
              {work.data.responsibilities.slice(0, 3).map((role) => (
                <span>{role}</span>
              ))}
              <span>{work.data.playCount}</span>
            </div>
          </div>
        </article>
      ))}
    </div>
    <a class="button button--secondary" href={musicPath()}>音楽ページを見る</a>
  </section>

  <section class="section-card section-card--quiet" id="skills" data-reveal>
    <div class="section-heading">
      <p class="section-heading__eyebrow">Skills</p>
      <h2>言語・ツール</h2>
      <p class="section-heading__lead">
        主戦力の技術と、授業・短期使用に留まる技術を分けて記載しています。
      </p>
    </div>
    <SkillGrid groups={skillGroups} />
  </section>

  <section class="section-card section-card--quiet" data-reveal>
    <div class="section-heading">
      <p class="section-heading__eyebrow">Activity</p>
      <h2>展示・頒布歴</h2>
    </div>
    <Timeline items={activities} />
  </section>

  <section class="section-card section-card--quiet" data-reveal>
    <div class="section-heading">
      <p class="section-heading__eyebrow">Profile</p>
      <h2>制作の軸</h2>
    </div>
    <div class="profile-stack">
      {profileTimeline.map((line, index) => (
        <p style={`--reveal-delay: ${90 + index * 70}ms;`} data-reveal>{line}</p>
      ))}
    </div>
  </section>

  <section class="section-card section-card--quiet" id="contact" data-reveal>
    <div class="section-heading">
      <p class="section-heading__eyebrow">Contact</p>
      <h2>連絡先 / 外部リンク</h2>
    </div>
    <div class="contact-panel">
      <div>
        <p class="contact-panel__label">Mail</p>
        <a class="contact-panel__mail" href={`mailto:${siteMeta.contactEmail}`}>
          {siteMeta.contactEmail}
        </a>
      </div>
      <ul class="contact-list">
        {normalizedContactLinks.map((item) => (
          <li>
            {item.url ? (
              <a href={item.url} target="_blank" rel="noreferrer">
                {item.label}
              </a>
            ) : (
              <span>{item.label}</span>
            )}
            {item.note && <small>{item.note}</small>}
          </li>
        ))}
      </ul>
    </div>
  </section>
</BaseLayout>
