---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import Hero from "@components/Hero.astro";
import ProjectIndexList from "@components/ProjectIndexList.astro";
import { aboutLines, contactLinks, heroTechStack, siteMeta } from "@content/site";
import { musicPath } from "@utils/paths";

const projects = (await getCollection("projects")).sort(
  (left, right) => left.data.sortOrder - right.data.sortOrder
);
const normalizedContactLinks = contactLinks.map((link) => ({
  label: link.label,
  url: "url" in link ? link.url : undefined
}));
---

<BaseLayout>
  <Hero
    name={siteMeta.name}
    roleLine={siteMeta.roleLine}
    summary={siteMeta.heroSummary}
    techStack={heroTechStack}
    primaryHref="#works"
    musicHref={musicPath()}
  />

  <section class="section-card section-card--spotlight" id="works" data-reveal>
    <div class="section-heading">
      <p class="section-heading__eyebrow">Works</p>
      <h2>ゲーム作品</h2>
      <p class="section-heading__lead">
        作品カードに触れると、反対側のセルに詳細が切り替わります。クリックか Enter / Space で選択を固定できます。
      </p>
    </div>
    <ProjectIndexList items={projects} />
  </section>

  <section class="section-card section-card--quiet" id="about" data-reveal>
    <div class="section-heading">
      <p class="section-heading__eyebrow">About</p>
      <h2>制作の軸</h2>
      <p class="section-heading__lead">
        主担当領域、使う技術、展示・頒布実績だけを短くまとめています。
      </p>
    </div>
    <div class="about-list">
      {aboutLines.map((item, index) => (
        <article class="about-item" style={`--reveal-delay: ${90 + index * 70}ms;`} data-reveal>
          <h3>{item.title}</h3>
          <p>{item.text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section-card section-card--quiet" id="contact" data-reveal>
    <div class="section-heading">
      <p class="section-heading__eyebrow">Contact</p>
      <h2>連絡先</h2>
    </div>
    <div class="contact-stack">
      <a class="contact-stack__mail" href={`mailto:${siteMeta.contactEmail}`}>
        {siteMeta.contactEmail}
      </a>
      <ul class="contact-stack__links">
        {normalizedContactLinks.map((item) => (
          <li>
            {item.url ? (
              <a href={item.url} target="_blank" rel="noreferrer">
                {item.label}
              </a>
            ) : (
              <span>{item.label}</span>
            )}
          </li>
        ))}
        <li>
          <a href={musicPath()}>音楽ページ</a>
        </li>
      </ul>
    </div>
  </section>
</BaseLayout>
