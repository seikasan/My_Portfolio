---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import GameCard from '../components/GameCard.astro';
import MusicCard from '../components/MusicCard.astro';
import { siteMeta, profile, skills, contact } from '../data/site.js';

const games = (await getCollection('games')).sort((a, b) => a.data.order - b.data.order);
const musicEntries = (await getCollection('music-video')).sort((a, b) => a.data.order - b.data.order);
const root = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout title="Home" description={siteMeta.intro}>
  <section class="hero section">
    <div class="hero-copy panel">
      <p class="eyebrow">Portfolio</p>
      <h1>{siteMeta.ownerName}</h1>
      <p class="hero-role">{siteMeta.role}</p>
      <p class="hero-tagline">{siteMeta.tagline}</p>
      <p class="hero-description">{siteMeta.intro}</p>
      <div class="hero-actions">
        <a class="button" href="#works-games">View games</a>
        <a class="button button--ghost" href="#works-music">View music / video</a>
      </div>
    </div>
  </section>

  <section class="section" id="about">
    <SectionHeader eyebrow="About" title="Profile" description={profile.comment} />
    <div class="two-column">
      <div class="panel">
        <h3>Timeline</h3>
        <ul class="timeline-list">
          {profile.timeline.map((item) => (
            <li>
              <span>{item.label}</span>
              <p>{item.text}</p>
            </li>
          ))}
        </ul>
      </div>
      <div class="stack">
        <div class="panel">
          <h3>Education</h3>
          <ul class="simple-list">
            {profile.education.map((item) => <li>{item}</li>)}
          </ul>
        </div>
        <div class="panel">
          <h3>Events</h3>
          <ul class="simple-list">
            {profile.events.map((item) => <li>{item}</li>)}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="skills">
    <SectionHeader eyebrow="Skills" title="Capabilities" description={skills.summary} />
    <div class="two-column">
      <div class="panel">
        <h3>Languages</h3>
        <ul class="skill-list">
          {skills.languages.map((item) => (
            <li>
              <strong>{item.name}</strong>
              <span>{item.experience}</span>
            </li>
          ))}
        </ul>
      </div>
      <div class="panel">
        <h3>Tools</h3>
        <ul class="skill-list">
          {skills.tools.map((item) => (
            <li>
              <strong>{item.name}</strong>
              <span>{item.experience}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="section" id="works-games">
    <SectionHeader
      eyebrow="Works - Games"
      title="Selected Games"
      description="Game projects with period, roles, stack, and contribution."
      actionHref={`${root}games/`}
      actionLabel="Browse all games"
    />
    <div class="card-grid">
      {games.map((entry) => <GameCard entry={entry} />)}
    </div>
  </section>

  <section class="section" id="works-music">
    <SectionHeader
      eyebrow="Works - Music / Video"
      title="Music / Video"
      description="Selected media work with embedded previews and supporting links."
      actionHref={`${root}music-video/`}
      actionLabel="Browse all music / video"
    />
    <div class="card-grid card-grid--music">
      {musicEntries.map((entry) => <MusicCard entry={entry} />)}
    </div>
  </section>

  <section class="section" id="contact">
    <SectionHeader
      eyebrow="Contact"
      title="Contact"
      description="External links and a direct contact address."
    />
    <div class="two-column">
      <a class="panel contact-card" href={contact.github} target="_blank" rel="noreferrer">
        <strong>GitHub</strong>
        <span>{contact.github}</span>
      </a>
      <a class="panel contact-card" href={`mailto:${contact.email}`}>
        <strong>Email</strong>
        <span>{contact.email}</span>
      </a>
    </div>
  </section>
</BaseLayout>
