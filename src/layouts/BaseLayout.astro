---
import '../styles/global.css';
import { siteMeta } from '../data/site.js';

const { title = 'Portfolio', description = siteMeta.intro } = Astro.props;
const root = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const navItems = [
  { label: 'About', href: `${root}#about` },
  { label: 'Skills', href: `${root}#skills` },
  { label: 'Games', href: `${root}#works-games` },
  { label: 'Music / Video', href: `${root}#works-music` },
  { label: 'Contact', href: `${root}#contact` }
];
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Portfolio</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#ffffff" />
  </head>
  <body>
    <div class="page-shell">
      <header class="site-header">
        <div class="site-header__inner">
          <a class="brand" href={root}>{siteMeta.ownerName}</a>
          <nav class="site-nav" aria-label="Primary">
            {navItems.map((item) => (
              <a href={item.href}>{item.label}</a>
            ))}
          </nav>
        </div>
      </header>
      <main class="site-main">
        <slot />
      </main>
      <footer class="site-footer">
        <div class="site-footer__inner">
          <p>{siteMeta.ownerName}</p>
          <p>Games / Music / Scenario / 3D / Programming</p>
        </div>
      </footer>
    </div>
  </body>
</html>
